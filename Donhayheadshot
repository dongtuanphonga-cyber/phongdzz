}
$('btnFind').onclick = async () => {
  if (!document.body.classList.contains('unlocked')) { showToast('🔒 Nhập KEY trước!'); return; }
  if (findRunning) return;
  findRunning = true;
  const btnFind = $('btnFind');
  const total = 1900 + probs.length * 300 + Math.round(Math.random() * 500);
  btnFind.classList.add('btn-loading');
  const fTxtEl = document.getElementById('fTxt');
  const old = fTxtEl ? fTxtEl.textContent : '🔍 TÌM ĐỘ NHẠY';
  if (fTxtEl) fTxtEl.textContent = 'Đang tìm...';
  const findBar=$('findBar'),progWrap=$('progWrap'),findMsg=$('findMsg'),progFill=$('progFill'),findTime=$('findTime');
  findBar.classList.remove('hide'); progWrap.classList.remove('hide'); findMsg.classList.remove('hide');
  progFill.style.width = '0%'; findMsg.textContent = FMSGS[0];
  let elapsed = 0, msgIdx = 0;
  const timer = setInterval(() => {
    elapsed += 55;
    progFill.style.width = Math.min(94, elapsed / total * 100) + '%';
    findTime.textContent = (elapsed / 1000).toFixed(1) + 's';
    const ni = Math.floor(elapsed / total * FMSGS.length);
    if (ni !== msgIdx && ni < FMSGS.length) { msgIdx = ni; findMsg.textContent = FMSGS[ni]; }
  }, 55);
  await new Promise(r => setTimeout(r, total));
  clearInterval(timer);
  progFill.style.width = '100%'; findMsg.textContent = '✅ Xong!';
  const model = curOS === 'ios' ? iosSel.value : adrSel.value;
  const baseResult = applyProbs(baseSens(curOS, model, curBrand, curGame, curTier), probs);
  lastResult = { s: baseResult.s, adj: baseResult.adj };
  const finalResult = applyEsportMode(baseResult.s, baseResult.adj);
  try { renderSens(finalResult.s, finalResult.adj); } catch(e) { console.error('renderSens:', e); }
  showResultPage();
  updateEsportButton();
  const aiBox = $('aiBox'), aiText = $('aiText'), tipBox = $('tipBox');
  let ai = curOS === 'ios'
    ? 'iOS cảm ứng ổn định - AI CriperLegend General kéo chính xác. '
    : 'Android thường nặng tâm hơn iOS - AI tăng Free Look để xoay màn thoáng hơn. ';
  if (probs.length) {
    const pMap = {lo_dau:'Lố đầu: giảm Red Dot. ',lac_dan:'Lạc đạn: siết 2x/4x. ',giat_tam:'Giật tâm: hạ nhạy ngang. ',nang_tam:'Nặng tâm: tăng Free Look. ',rung_tay:'Rung tay: hạ đều. ',truot_dich:'Trượt địch: tăng bắt mục tiêu. '};
    ai += probs.map(p => pMap[p] || '').join('');
  } else ai += 'Không có vấn đề đặc biệt - bộ số chuẩn tối ưu OB53. ';
  if (curTier === 'vv' || curTier === 'vip3day') ai += '[Premium VIP⚙️] Tinh chỉnh sâu thêm 20%.';
  if (esportMode) ai += ' [Esport Mode] Tăng phản xạ General/Red Dot/Free Look để kéo nhanh hơn.';
  if (aiText) { aiText.textContent = ai.trim(); }
  if (aiBox) aiBox.classList.add('show');
  tipBox.className = (curTier === 'vv' || curTier === 'vip3day') ? 'tipbox vv-tip' : 'tipbox';
  tipBox.innerHTML = probs.length
    ? '💡 <strong>Đã điều chỉnh:</strong><br>' + probs.map(p => TIPS[p]).filter(Boolean).join('<br>') + (esportMode ? '<br>🎮 <strong>Esport Mode:</strong> tăng thêm phản xạ kéo tâm và tốc độ xoay.' : '')
    : '✅ <strong>Độ nhạy chuẩn OB53</strong> - không có vấn đề đặc biệt.' + (esportMode ? '<br>🎮 <strong>Esport Mode:</strong> đang bật để ưu tiên phản xạ.' : '');
  tipBox.classList.remove('hide');
  setTimeout(() => {
    try { findBar.classList.add('hide'); progWrap.classList.add('hide'); findMsg.classList.add('hide'); } catch(e){}
    try { btnFind.classList.remove('btn-loading'); if (fTxtEl) fTxtEl.textContent = old; } catch(e){}
    findRunning = false;
  }, 800);
  showToast('✅ Đã tìm xong độ nhạy!');
};

