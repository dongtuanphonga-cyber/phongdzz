// RENDER SENSITIVITY
// ══════════════════════════════════
function calcShootButton(os, model, brand, tier, probs){
  let size = 29;
  if (os === 'ios') {
    const g = iosGrp(model);
    const map = { old: 35, mid: 32, midn: 30, new: 28, newp: 26, pro: 24, ultra: 23 };
    size = map[g] || 29;
  } else {
    const t = adrTier(brand, model);
    const map = { entry: 35, mid: 33, umid: 31, flag: 29, ultra: 27 };
    size = map[t] || 32;
  }
  if (probs.includes('rung_tay')) size += 1;
  if (probs.includes('nang_tam')) size += 1;
  if (probs.includes('truot_dich')) size -= 1;
  if (tier === 'threeday') size -= 1;
  if (tier === 'vip3day' || tier === 'vv') size -= 2;
  size = Math.max(23, Math.min(35, size));
  return size;
}
function applyEsportMode(s, adj) {
  if (!esportMode) return { s: { ...s }, adj: { ...adj } };
  const ns = { ...s };
  const na = { ...adj };
  const boosts = { g: 6, r: 5, x2: 4, x4: 2, aw: -2, fl: 7 };
  const ranges = { g:[70,200], r:[70,200], x2:[60,195], x4:[55,185], aw:[35,145], fl:[70,200] };
  for (const k of Object.keys(boosts)) {
    ns[k] = Math.max(ranges[k][0], Math.min(ranges[k][1], ns[k] + boosts[k]));
    na[k] += boosts[k];
  }
  return { s: ns, adj: na };
}

function animNum(el, to) {
  const from = parseInt(el.textContent) || 0, t0 = performance.now(), dur = 550;
  const tick = t => {
    const p = Math.min(1, (t - t0) / dur), e = 1 - Math.pow(1 - p, 4);
    el.textContent = Math.round(from + (to - from) * e);
    if (p < 1) requestAnimationFrame(tick);
  };
  requestAnimationFrame(tick);
}
function renderSens(s, adj) {
  const model = curOS === 'ios' ? iosSel.value : adrSel.value;
  $('devName').textContent = model;
  $('devSub').textContent  = `${curGame === 'ff' ? 'Free Fire' : 'Free Fire MAX'} · ${curOS === 'ios' ? 'iOS' : 'Android'} · OB53`;
  $('gamePill').textContent = curGame === 'ff' ? '🔥 Free Fire' : '💎 FF MAX';
  const shootVal = calcShootButton(curOS, model, curBrand, curTier, probs);
  const shootAdj = shootVal - 29;
  const MAP = [['vG','adG',s.g,adj.g],['vR','adR',s.r,adj.r],['v2','ad2',s.x2,adj.x2],['v4','ad4',s.x4,adj.x4],['vA','adA',s.aw,adj.aw],['vF','adF',s.fl,adj.fl],['vS','adS',shootVal,shootAdj]];
  MAP.forEach(([vid,aid,val,d]) => {
    const ve = $(vid), ae = $(aid);
    ve.classList.remove('up', 'dn');
    if (d > 0) ve.classList.add('up'); else if (d < 0) ve.classList.add('dn');
    ve.textContent === '-' ? ve.textContent = val : animNum(ve, val);
    if (d !== 0) { ae.textContent = d > 0 ? `▲ +${d}` : `▼ ${d}`; ae.className = 'sadj show ' + (d > 0 ? 'aup' : 'adn'); }
    else { ae.className = 'sadj'; ae.textContent = ''; }
  });
  if (curTier === 'vv' || curTier === 'vip3day') {
    const aim=Math.min(99,Math.round(90+(s.r+s.x2)/2*.05)),stab=Math.min(99,Math.round(95-s.g*.05)),scope=Math.min(99,Math.round((s.x2+s.x4)/2*.44)),total=Math.min(99,Math.round((aim+stab+scope)/3));
    $('vvAim').textContent=aim+'%';$('vvStab').textContent=stab+'%';$('vvScope').textContent=scope+'%';$('vvTotal').textContent=total+'%';
    $('vvPanel').classList.add('show');
  } else $('vvPanel').classList.remove('show');
}

