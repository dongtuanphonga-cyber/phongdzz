<title>CDUCDZ VIP · OB53</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&amp;family=Be+Vietnam+Pro:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
<style>
:root{
  --bg:#030810;--text:#edf5ff;--sub:#8ea7c6;--muted:#4e6880;--line:rgba(255,255,255,.09);
  --teal:#11f2d7;--blue:#59a8ff;--purple:#ae6dff;--gold:#ffd84f;--gold2:#ffb429;
  --pink:#ff4da0;--ok:#4cffc6;--bad:#ff7e98;--r:22px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}
input,select{-webkit-user-select:text!important;user-select:text!important}
html{touch-action:pan-y;overscroll-behavior:contain;-webkit-text-size-adjust:100%}
body{min-height:100vh;background:var(--bg);color:var(--text);font-family:'Be Vietnam Pro',sans-serif;overflow-x:hidden;-webkit-tap-highlight-color:transparent}


#splash{
position:fixed;inset:0;z-index:99999;
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;
background:radial-gradient(ellipse 120% 80% at 50% 60%, #06102a 0%, #030810 65%);
overflow:hidden;
}
#splash.exiting{animation:splashOut .55s cubic-bezier(.7,0,.85,1) forwards}
@keyframes splashOut{to{opacity:0;transform:scale(1.05);pointer-events:none}}

/* ── Ambient background rays ── */
.sp-rays{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.sp-ray{
position:absolute;left:50%;top:50%;
width:2px;height:55vh;transform-origin:top center;
background:linear-gradient(180deg,rgba(17,242,215,.0),rgba(17,242,215,.18),transparent);
opacity:0;animation:rayAppear 1s ease var(--rd,.5s) forwards;
}
@keyframes rayAppear{from{opacity:0;transform:rotate(var(--r,0deg)) scaleY(0)}to{opacity:1;transform:rotate(var(--r,0deg)) scaleY(1)}}
.sp-ray-fade{animation:rayFade 2s ease 2.2s forwards}
@keyframes rayFade{to{opacity:0}}

/* ── Logo container ── */
.sp-logo{
position:relative;
width:220px;height:220px;
display:flex;align-items:center;justify-content:center;
margin-bottom:28px;
}

/* ── Outer ambient glow ── */
.sp-glow-outer{
position:absolute;inset:-40px;border-radius:999px;
background:radial-gradient(circle,rgba(17,242,215,.22) 0%,rgba(89,168,255,.10) 40%,transparent 70%);
animation:outerGlowIn .8s ease 1.8s both,outerGlowPulse 3s ease-in-out 2.6s infinite alternate;
}
@keyframes outerGlowIn{from{opacity:0;transform:scale(.5)}to{opacity:1;transform:scale(1)}}
@keyframes outerGlowPulse{from{transform:scale(.9);opacity:.7}to{transform:scale(1.12);opacity:1}}

/* ── SVG arc ring assembly ── */
.sp-ring-svg{
position:absolute;inset:-16px;
width:calc(100% + 32px);height:calc(100% + 32px);
overflow:visible;
}
/* circumference of r=111: ~697, quarter = 174 */
.ring-track{opacity:.06}
.ring-arc{
stroke-dasharray:174 523;
stroke-dashoffset:174;
stroke-linecap:round;stroke-width:6;fill:none;
transform-origin:126px 126px;
}
/* Arc 1 - teal - sweeps in from top-right */
.arc1{
stroke:#11f2d7;
filter:drop-shadow(0 0 8px rgba(17,242,215,1)) drop-shadow(0 0 20px rgba(17,242,215,.5));
animation:arcDraw .5s cubic-bezier(.4,0,.2,1) .05s both, arcFly1 .5s cubic-bezier(.34,1.36,.64,1) .05s both;
}
/* Arc 2 - blue */
.arc2{
stroke:#59a8ff;
filter:drop-shadow(0 0 8px rgba(89,168,255,1)) drop-shadow(0 0 20px rgba(89,168,255,.5));
animation:arcDraw .5s cubic-bezier(.4,0,.2,1) .22s both, arcFly2 .5s cubic-bezier(.34,1.36,.64,1) .22s both;
}
/* Arc 3 - purple */
.arc3{
stroke:#ae6dff;
filter:drop-shadow(0 0 8px rgba(174,109,255,1)) drop-shadow(0 0 20px rgba(174,109,255,.5));
animation:arcDraw .5s cubic-bezier(.4,0,.2,1) .39s both, arcFly3 .5s cubic-bezier(.34,1.36,.64,1) .39s both;
}
/* Arc 4 - pink */
.arc4{
stroke:#ff4da0;
filter:drop-shadow(0 0 8px rgba(255,77,160,1)) drop-shadow(0 0 20px rgba(255,77,160,.5));
animation:arcDraw .5s cubic-bezier(.4,0,.2,1) .56s both, arcFly4 .5s cubic-bezier(.34,1.36,.64,1) .56s both;
}
@keyframes arcDraw{from{stroke-dashoffset:174}to{stroke-dashoffset:0}}
@keyframes arcFly1{from{transform:rotate(-90deg) translateY(-30px);opacity:0}to{transform:rotate(-90deg) translateY(0);opacity:1}}
@keyframes arcFly2{from{transform:rotate(0deg) translateX(30px);opacity:0}to{transform:rotate(0deg) translateX(0);opacity:1}}
@keyframes arcFly3{from{transform:rotate(90deg) translateY(30px);opacity:0}to{transform:rotate(90deg) translateY(0);opacity:1}}
@keyframes arcFly4{from{transform:rotate(180deg) translateX(-30deg);opacity:0}to{transform:rotate(180deg) translateX(0);opacity:1}}

/* Flash khi vòng hoàn chỉnh */
.ring-flash{stroke:#fff;stroke-width:8;fill:none;stroke-dasharray:697;stroke-dashoffset:0;opacity:0;animation:ringFlash .6s ease .9s}
@keyframes ringFlash{0%{opacity:0}30%{opacity:.7;stroke-width:14;filter:drop-shadow(0 0 20px #fff)}100%{opacity:0;stroke-width:6}}

/* ── Spinning orbit dots ── */
.sp-orbit-wrap{
position:absolute;inset:-16px;
border-radius:999px;opacity:0;
animation:orbitIn .3s ease 1.0s forwards;
}
@keyframes orbitIn{to{opacity:1}}
.sp-orbit{position:absolute;inset:0;border-radius:999px;animation:orbitSpin 3.2s linear infinite}
@keyframes orbitSpin{to{transform:rotate(360deg)}}
.sp-dot-a{position:absolute;top:-1px;left:50%;transform:translateX(-50%);width:12px;height:12px;border-radius:999px;background:var(--teal);box-shadow:0 0 18px rgba(17,242,215,1),0 0 36px rgba(17,242,215,.6)}
.sp-orbit2{position:absolute;inset:8px;border-radius:999px;animation:orbitSpin 5s linear infinite reverse}
.sp-dot-b{position:absolute;bottom:-1px;right:22%;width:8px;height:8px;border-radius:999px;background:var(--purple);box-shadow:0 0 12px rgba(174,109,255,.9)}

/* ── Avatar reveal ── */
.sp-avt{
position:relative;z-index:4;
width:188px;height:188px;border-radius:999px;overflow:hidden;
border:2px solid rgba(17,242,215,.25);
box-shadow:
0 0 0 1px rgba(17,242,215,.12),
0 0 40px rgba(17,242,215,.35),
0 0 80px rgba(89,168,255,.18),
0 30px 80px rgba(0,0,0,.55);
opacity:0;
animation:avtReveal .65s cubic-bezier(.34,1.52,.64,1) 1.05s both;
}
@keyframes avtReveal{
0%{opacity:0;transform:scale(.28) rotate(8deg);filter:blur(12px) brightness(3)}
60%{filter:blur(0) brightness(1.15)}
100%{opacity:1;transform:scale(1) rotate(0deg);filter:blur(0) brightness(1)}
}
.sp-avt img{width:100%;height:100%;object-fit:cover;border-radius:999px;display:block}
.sp-avt-shine{
position:absolute;inset:0;border-radius:999px;
background:linear-gradient(135deg,rgba(255,255,255,.35) 0%,transparent 45%);
opacity:0;animation:shineIn .5s ease 1.55s forwards;
}
@keyframes shineIn{to{opacity:1}}
/* Name bar inside avatar */
.sp-avt-name{
position:absolute;bottom:0;left:0;right:0;
padding:22px 8px 10px;
background:linear-gradient(transparent,rgba(3,7,14,.92));
font-family:'Rajdhani',sans-serif;font-size:14px;font-weight:700;letter-spacing:3px;
color:#fff;text-align:center;
text-shadow:0 0 20px rgba(17,242,215,1),0 2px 6px rgba(0,0,0,.9);
opacity:0;animation:sTextIn .4s ease 1.55s forwards;
}
/* Pulse ring after avatar appears */
.sp-avt-pulse{
position:absolute;inset:-8px;border-radius:999px;
border:2px solid var(--teal);opacity:0;
animation:pulseRingA 1.8s ease-out 1.7s infinite;
}
.sp-avt-pulse2{
position:absolute;inset:-18px;border-radius:999px;
border:1px solid rgba(17,242,215,.4);opacity:0;
animation:pulseRingA 1.8s ease-out 2s infinite;
}
@keyframes pulseRingA{
0%{opacity:.8;transform:scale(.96)}
100%{opacity:0;transform:scale(1.18)}
}

/* ── Text section ── */
.sp-title{
font-family:'Rajdhani',sans-serif;font-size:30px;font-weight:700;letter-spacing:4.5px;
background:linear-gradient(90deg,var(--teal),var(--blue),var(--purple),var(--pink),var(--teal));
background-size:250% 100%;
-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
animation:sTextIn .65s cubic-bezier(.16,1,.3,1) .75s both,titleShimmer 3s linear 1.5s infinite;
}
@keyframes titleShimmer{0%{background-position:0%}100%{background-position:250%}}
.sp-sub{
font-size:11px;letter-spacing:4px;color:var(--muted);text-transform:uppercase;margin-top:7px;
animation:sTextIn .6s .92s both;
}
.sp-tagline{
font-family:'Rajdhani',sans-serif;font-size:13px;font-weight:600;letter-spacing:1.8px;
color:var(--teal);margin-top:5px;opacity:.85;
animation:sTextIn .6s 1.05s both;
}
@keyframes sTextIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
/* Progress bar */
.sp-bar-wrap{
width:170px;height:3px;border-radius:999px;
background:rgba(255,255,255,.07);margin-top:26px;overflow:hidden;
animation:sTextIn .5s 1.15s both;
}
.sp-bar{
height:100%;width:0;border-radius:999px;
background:linear-gradient(90deg,var(--teal),var(--blue),var(--purple),var(--pink));
animation:spBarFill 2.1s cubic-bezier(.4,0,.2,1) 1.25s forwards;
}
@keyframes spBarFill{0%{width:0}55%{width:68%}82%{width:90%}100%{width:100%}}
.sp-ver{font-family:'Rajdhani',sans-serif;font-size:10px;color:var(--muted);letter-spacing:1.5px;margin-top:11px;animation:sTextIn .5s 1.35s both}
/* Floating particles in splash */
.spt{position:absolute;width:2px;height:2px;border-radius:999px;background:rgba(17,242,215,.75);filter:drop-shadow(0 0 5px rgba(17,242,215,.5));opacity:0;animation:sptUp var(--t,8s) linear infinite}
@keyframes sptUp{0%{transform:translate(var(--x,0),65vh) scale(.6);opacity:0}10%{opacity:.8}100%{transform:translate(var(--x2,0),-10vh) scale(1.3);opacity:0}}

/* ════════════════════════════════════════
SUCCESS SCREEN - Dev terminal style
════════════════════════════════════════ */
#successScreen{
position:fixed;inset:0;z-index:9990;
display:none;flex-direction:column;align-items:center;justify-content:center;
background:rgba(2,5,12,.97);backdrop-filter:blur(30px);
padding:28px 20px;overflow-y:auto;
}
#successScreen.show{display:flex;animation:ssFadeIn .3s ease}
@keyframes ssFadeIn{from{opacity:0}to{opacity:1}}
.ss-term{width:100%;max-width:380px;border-radius:14px;overflow:hidden;border:1px solid rgba(17,242,215,.22);box-shadow:0 0 50px rgba(17,242,215,.09)}
.ss-term-bar{display:flex;align-items:center;gap:7px;padding:10px 14px;background:rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06)}
.ssd{width:10px;height:10px;border-radius:999px}.ssd.r{background:#ff5f57}.ssd.y{background:#ffbd2e}.ssd.g{background:#28c840}
.ss-term-ttl{font-family:'Rajdhani',sans-serif;font-size:11px;letter-spacing:1px;color:var(--muted);margin:0 auto}
.ss-term-body{padding:14px 16px;background:rgba(3,8,20,.92);font-family:'Rajdhani',sans-serif;font-size:12.5px;letter-spacing:.5px;line-height:2}
.ss-line{display:flex;gap:8px;opacity:0;animation:ssLIn .25s ease forwards}
@keyframes ssLIn{to{opacity:1}}
.ss-prompt{color:var(--teal);flex-shrink:0;font-weight:700}.ss-txt{color:#c8dff4}
.ss-ok{color:var(--ok);font-weight:700}
.ss-check-area{position:relative;margin:24px 0 14px;width:104px;height:104px;display:flex;align-items:center;justify-content:center}
.ss-ring-s{position:absolute;inset:0;border-radius:999px;animation:ringSpin 1.6s linear infinite}
.ss-ring-s::before{content:"";position:absolute;inset:0;border-radius:999px;background:conic-gradient(from 0deg,currentColor 0%,transparent 45%,currentColor 100%)}
.ss-ring-s::after{content:"";position:absolute;inset:5px;border-radius:999px;background:rgba(2,5,13,.97)}
.ss-chk{position:relative;z-index:2;width:68px;height:68px;border-radius:999px;display:flex;align-items:center;justify-content:center;animation:chkPop .5s cubic-bezier(.16,1.3,.3,1) both}
@keyframes chkPop{from{transform:scale(.4);opacity:0}to{transform:scale(1);opacity:1}}
.ss-chk svg{width:32px;height:32px}
.ss-title{font-family:'Rajdhani',sans-serif;font-size:24px;font-weight:700;letter-spacing:1px;text-align:center}
.ss-sub{font-size:12px;color:var(--sub);text-align:center;margin-top:5px;line-height:1.55}
.ss-pill{display:inline-flex;align-items:center;gap:6px;padding:7px 18px;border-radius:999px;border:1px solid;font-family:'Rajdhani',sans-serif;font-size:12px;font-weight:700;letter-spacing:.7px;margin-top:10px}
.ss-btn{margin-top:20px;padding:14px 36px;border:none;border-radius:16px;cursor:pointer;font-family:'Rajdhani',sans-serif;font-size:16px;font-weight:700;letter-spacing:1px;background:linear-gradient(135deg,var(--teal),var(--blue));color:#04131a;box-shadow:0 12px 40px rgba(17,242,215,.22);position:relative;overflow:hidden}
.ss-btn::before{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,255,255,.18),transparent 55%)}
.ss-btn:active{transform:scale(.97)}

/* ════════════════════════════════════════
BG & AMBIENT
════════════════════════════════════════ */
.bg{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;
background:radial-gradient(ellipse 900px 620px at 8% 8%,rgba(17,242,215,.14),transparent 58%),
radial-gradient(ellipse 760px 540px at 92% 12%,rgba(89,168,255,.12),transparent 56%),
radial-gradient(ellipse 820px 580px at 50% 100%,rgba(174,109,255,.10),transparent 62%),
linear-gradient(180deg,#02050d 0%,#07101e 50%,#030810 100%)}
.bg::before{content:"";position:absolute;inset:-24%;background:conic-gradient(from 0deg,rgba(17,242,215,.025),rgba(89,168,255,.04),rgba(174,109,255,.04),rgba(255,77,160,.03),rgba(17,242,215,.025));filter:blur(52px);animation:bgSpin 26s linear infinite}
.grid-lines{position:fixed;inset:0;z-index:0;pointer-events:none;opacity:.022;background-image:linear-gradient(rgba(17,242,215,1) 1px,transparent 1px),linear-gradient(90deg,rgba(17,242,215,1) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(circle at center,black 28%,transparent 100%)}
.orb{position:fixed;border-radius:999px;pointer-events:none;z-index:0;filter:blur(34px);opacity:.2;animation:floatOrb 18s ease-in-out infinite alternate}
.o1{width:230px;height:230px;left:1%;top:10%;background:rgba(17,242,215,.28)}
.o2{width:300px;height:300px;right:-50px;top:13%;background:rgba(89,168,255,.22);animation-duration:22s}
.o3{width:240px;height:240px;left:32%;bottom:0;background:rgba(174,109,255,.20);animation-duration:26s}
.scanline{position:fixed;left:0;right:0;height:2px;z-index:1;pointer-events:none;background:linear-gradient(90deg,transparent,rgba(17,242,215,.28),rgba(89,168,255,.45),rgba(17,242,215,.28),transparent);animation:scanMove 6s linear infinite;opacity:.4}
.pts{position:fixed;inset:0;z-index:1;pointer-events:none;overflow:hidden}
.pt{position:absolute;width:2px;height:2px;border-radius:999px;background:rgba(17,242,215,.85);filter:drop-shadow(0 0 7px rgba(17,242,215,.4));opacity:0;animation:ptUp var(--t,10s) linear infinite}

/* ════════════════════════════════════════
LAYOUT
════════════════════════════════════════ */
.wrap{position:relative;z-index:2;max-width:980px;margin:0 auto;padding:14px 14px 96px}
.grid{display:grid;grid-template-columns:1fr;gap:12px}
@media(min-width:920px){.grid{grid-template-columns:360px 1fr}}
.hide{display:none!important}

/* ════════════════════════════════════════
CARD
════════════════════════════════════════ */
.card{
position:relative;overflow:hidden;border-radius:var(--r);border:1px solid var(--line);
background:linear-gradient(160deg,rgba(255,255,255,.07),rgba(255,255,255,.03));
box-shadow:inset 0 1px 0 rgba(255,255,255,.08),0 28px 100px rgba(0,0,0,.60);
backdrop-filter:blur(24px) saturate(150%);-webkit-backdrop-filter:blur(24px) saturate(150%);
animation:cardIn .65s cubic-bezier(.16,1,.3,1) both;
}
.card::before{content:"";position:absolute;inset:0;pointer-events:none;background:radial-gradient(circle at 18% 10%,rgba(255,255,255,.08),transparent 40%),linear-gradient(180deg,rgba(255,255,255,.04),transparent 35%)}
.hd{display:flex;align-items:center;gap:10px;padding:14px 16px 12px;border-bottom:1px solid rgba(255,255,255,.06)}
.hd-ic{width:38px;height:38px;border-radius:12px;display:grid;place-items:center;flex:0 0 auto;font-size:16px;background:linear-gradient(135deg,rgba(17,242,215,.14),rgba(89,168,255,.12));border:1px solid rgba(17,242,215,.22)}
.hd-avt{width:38px;height:38px;border-radius:12px;overflow:hidden;flex:0 0 auto;border:1px solid rgba(17,242,215,.22)}
.hd-avt img{width:100%;height:100%;object-fit:cover;display:block}
.ht{font-family:'Rajdhani',sans-serif;font-size:15px;font-weight:700;letter-spacing:.7px;color:var(--teal)}
.hs{font-size:10.5px;color:var(--sub);margin-top:2px}
.bd{padding:14px}
.lbl{display:block;font-size:10px;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin:12px 0 6px}
.lbl:first-child{margin-top:0}
.center{text-align:center}

/* ════════════════════════════════════════
LOCK CARD AVATAR (spinning ring + real img)
════════════════════════════════════════ */
.avt-wrap{display:flex;align-items:center;justify-content:center;padding:22px 0 6px}
.avt-frame{position:relative;width:148px;height:148px;display:flex;align-items:center;justify-content:center}
.avt-ring-spin{position:absolute;inset:-5px;border-radius:999px;animation:ringSpin 3s linear infinite}
.avt-ring-spin::before{content:"";position:absolute;inset:0;border-radius:999px;background:conic-gradient(from 0deg,rgba(17,242,215,.96),rgba(89,168,255,.82),rgba(174,109,255,.72),rgba(255,77,160,.82),rgba(17,242,215,.96))}
.avt-ring-spin::after{content:"";position:absolute;inset:5px;border-radius:999px;background:var(--bg)}
.avt-img{position:relative;z-index:3;width:132px;height:132px;border-radius:999px;overflow:hidden;border:1px solid rgba(17,242,215,.24);box-shadow:0 0 32px rgba(17,242,215,.16);animation:avtCardPulse 3s ease-in-out infinite}
@keyframes avtCardPulse{0%,100%{box-shadow:0 0 26px rgba(17,242,215,.14)}50%{box-shadow:0 0 46px rgba(17,242,215,.3)}}
.avt-img img{width:100%;height:100%;object-fit:cover;display:block}
.avt-name{
font-family:'Rajdhani',sans-serif;font-size:20px;font-weight:700;letter-spacing:1.8px;
background:linear-gradient(90deg,var(--teal),var(--blue),var(--purple),var(--pink),var(--teal));
background-size:300% 100%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
animation:nameFlow 3s linear infinite;margin-top:10px;text-align:center;
}
.avt-sub{font-size:10px;letter-spacing:2.2px;color:var(--muted);text-transform:uppercase;margin-top:2px;text-align:center}
.lock-title{margin-top:16px;font-family:'Rajdhani',sans-serif;font-size:24px;font-weight:700;letter-spacing:1.5px;animation:lockPulse 2s ease-in-out infinite alternate;text-align:center}
.lock-sub{margin-top:5px;font-size:12px;color:var(--sub);line-height:1.5;text-align:center}

/* ════════════════════════════════════════
KEY INPUT
════════════════════════════════════════ */
.key-input-wrap{position:relative;margin-top:4px}
.key-input-wrap input{
width:100%;padding:14px 48px 14px 15px;border-radius:16px;
border:1.5px solid rgba(255,255,255,.12);background:rgba(255,255,255,.04);
color:var(--text);outline:none;font-size:15px;font-family:'Rajdhani',sans-serif;letter-spacing:1px;
transition:border-color .22s,box-shadow .22s,background .22s;
}
.key-input-wrap input:focus{border-color:rgba(17,242,215,.65);box-shadow:0 0 0 3px rgba(17,242,215,.11),0 0 22px rgba(17,242,215,.08);background:rgba(17,242,215,.04)}
.key-input-wrap.valid input{border-color:rgba(17,242,215,.88);box-shadow:0 0 0 3px rgba(17,242,215,.14),0 0 30px rgba(17,242,215,.13)}
.key-input-wrap.invalid input{border-color:rgba(255,126,152,.75);box-shadow:0 0 0 3px rgba(255,126,152,.12)}
.key-input-wrap input::placeholder{color:var(--muted)}
.key-eye{position:absolute;right:12px;top:50%;transform:translateY(-50%);border:none;background:none;color:var(--muted);font-size:18px;cursor:pointer;padding:4px;transition:color .2s}
.key-eye:hover{color:var(--teal)}
.key-hint{margin-top:7px;font-family:'Rajdhani',sans-serif;font-size:11px;color:var(--muted);text-align:center;min-height:18px;letter-spacing:.4px}
.key-hint .cur{display:inline-block;width:1px;height:11px;background:var(--teal);margin-left:1px;animation:blinkC .7s step-end infinite;vertical-align:middle}
